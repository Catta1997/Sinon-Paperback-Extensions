{
  "name": "sinon-extensions",
  "repositoryName": "Sinon's Extensions (0.9)",
  "description": "Some Paperback Extensions",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint --type-aware --fix",
    "lint:check": "oxlint --type-aware",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "tsc": "tsc",
    "bundle": "paperback-cli bundle",
    "serve": "paperback-cli serve",
    "logcat": "paperback-cli logcat",
    "dev": "paperback-cli serve --watch -p 38613",
    "test": "npm run tsc && npm run lint:check && npm run format:check && npm run bundle",
    "prepare": "husky"
  },
  "devDependencies": {
    "@paperback/toolchain": "^1.0.0-alpha.57",
    "@paperback/types": "^1.0.0-alpha.57",
    "cheerio": "^1.1.2",
    "husky": "^9.1.7",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.32.0",
    "oxlint-tsgolint": "^0.9.0",
    "typescript": "^5.9.3"
  }
}
