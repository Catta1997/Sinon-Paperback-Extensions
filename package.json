{
  "name": "sinon-extensions",
  "private": true,
  "description": "Some Paperback Extensions",
  "type": "module",
  "scripts": {
    "tsc": "tsc",
    "lint": "oxlint --type-aware --fix",
    "lint:check": "oxlint --type-aware --deny-warnings",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "conformance": "npm run tsc && npm run lint:check && npm run format:check",
    "bundle": "paperback-cli bundle",
    "serve": "paperback-cli serve",
    "dev": "paperback-cli serve --watch --port 5264",
    "logcat": "paperback-cli logcat",
    "test": "paperback-cli test --output ./bundles/tests.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@paperback/toolchain": "^1.0.0-alpha.92",
    "@paperback/types": "^1.0.0-alpha.92",
    "@types/chai": "^5.2.3",
    "@types/upng-js": "^2.1.5",
    "chai": "^6.2.2",
    "cheerio": "^1.2.0",
    "fastest-levenshtein": "^1.0.16",
    "husky": "^9.1.7",
    "jpeg-js": "^0.4.4",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "paperback-interceptors": "github:Catta1997/paperback-interceptors",
    "stemmer": "^2.0.1",
    "typescript": "^6.0.3",
    "upng-js": "^2.1.0"
  },
  "repositoryName": "Sinon's Extensions (0.9)"
}
